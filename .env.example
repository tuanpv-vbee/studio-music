# For more information, please see the README.md

# Required: full `Cookie` header copied from a logged-in suno.com/create request
# (must contain __client). Used to obtain a JWT via Clerk.
SUNO_COOKIE=

# Suno's web client now sends these identifiers on every generate request.
# Capture them from your browser DevTools (Network → POST /api/generate/v2-web/):
#   - device-id header                   →  SUNO_DEVICE_ID
#   - body metadata.user_tier            →  SUNO_USER_TIER
#   - body metadata.create_session_token →  SUNO_CREATE_SESSION_TOKEN
#   - body `token` (a "P1_..." string)   →  SUNO_TURNSTILE_TOKEN
# When SUNO_TURNSTILE_TOKEN + SUNO_CREATE_SESSION_TOKEN are both set, generate
# posts directly to /api/generate/v2-web/ (no headless browser needed).
# Both the Turnstile token and create_session_token are short-lived; if generate
# returns `token_validation_failed` (HTTP 422), re-capture them from the browser.
SUNO_DEVICE_ID=
SUNO_USER_TIER=
SUNO_CREATE_SESSION_TOKEN=
SUNO_TURNSTILE_TOKEN=
